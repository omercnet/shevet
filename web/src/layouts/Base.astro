---
import '../styles/brand.css'
import ZigZag from '../components/ZigZag.astro'
import { getSiteSettings } from '../lib/queries'
const {title = 'שבט אמהות', description = ''} = Astro.props
const gtm = import.meta.env.PUBLIC_GTM_ID // set per environment
const settings = await getSiteSettings()
const waLink = settings?.phone ? `https://wa.me/${settings.phone.replace(/\D/g, '')}` : null
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {/* TODO: gate behind cookie consent per Israeli privacy law before loading */}
    {gtm && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtm}');`} />
    )}
  </head>
  <body>
    <header class="wrap site-head">
      <a href="/" class="logo"><img src="/brand/logo.png" alt="שבט אמהות" width="160" height="99" /></a>
      <button class="nav-toggle" type="button" aria-controls="site-nav" aria-expanded="false">תפריט</button>
      <nav id="site-nav">
        <a href="/doulas/">דולות</a>
        <a href="/professionals/">נשות מקצוע</a>
        <a href="/articles/">מאמרים</a>
        <a href="/benefits/">הטבות</a>
        <a href="/community/">קהילה</a>
      </nav>
    </header>
    <ZigZag />
    <main>
      <slot />
    </main>
    <footer class="wrap site-foot">
      <span>© שבט אמהות</span>
      <div class="foot-contact">
        {settings?.email && <a href={`mailto:${settings.email}`}>{settings.email}</a>}
        {settings?.phone && <a href={waLink ?? `tel:${settings.phone}`}>{settings.phone}</a>}
        {settings?.instagram && <a href={settings.instagram}>Instagram</a>}
      </div>
    </footer>
    {/* TODO: consent banner gates GTM ({gtm}) per Israeli privacy law */}
    <script>
      const header = document.querySelector('.site-head')
      const toggle = document.querySelector('.nav-toggle')
      toggle?.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true'
        toggle.setAttribute('aria-expanded', String(!isOpen))
        header?.toggleAttribute('data-nav-open', !isOpen)
      })
    </script>
    <style>
      .site-head { display:flex; align-items:center; justify-content:space-between; padding-block:1rem; gap:1rem; position:relative; }
      .logo { display:inline-flex; }
      .logo img { height: 52px; width:auto; }
      .nav-toggle { display:none; border:1px solid var(--line); border-radius:999px; background:var(--cream-2); color:var(--ink); font:inherit; font-weight:700; padding:.45rem 1rem; }
      .nav-toggle:focus-visible, .site-head nav a:focus-visible { outline:3px solid var(--peach); outline-offset:3px; }
      .site-head nav { display:flex; gap:1.2rem; flex-wrap:wrap; }
      .site-head nav a { text-decoration:none; color: var(--ink); font-weight:600; transition:color .18s ease; }
      .site-head nav a:hover { color:var(--brand); }
      .site-foot { padding-block:2rem; color: var(--muted); border-top:1px solid var(--line); margin-top:3rem; display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
      .foot-contact { display:flex; gap:1.2rem; flex-wrap:wrap; }
      .foot-contact a { color: var(--brand); text-decoration:none; }
      @media (max-width: 700px) {
        .site-head { padding-block:.7rem; }
        .logo img { height:46px; }
        .nav-toggle { display:inline-block; }
        .site-head nav { display:none; position:absolute; inset-inline:1rem; top:calc(100% + .35rem); z-index:10; background:var(--cream); border:1px solid var(--line); border-radius:18px; box-shadow:0 18px 40px -28px rgba(63, 34, 48, .65); padding:.8rem; }
        .site-head[data-nav-open] nav { display:grid; gap:.35rem; }
        .site-head nav a { padding:.55rem .7rem; border-radius:12px; }
        .site-head nav a:hover { background:var(--peach-soft); }
      }
    </style>
  </body>
</html>
