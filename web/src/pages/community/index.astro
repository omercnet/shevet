---
import Base from '../../layouts/Base.astro'
import {getCommunityPages, getSiteSettings, getWhatsappGroups} from '../../lib/queries'
import type {CommunityPage, WhatsappGroup} from '../../lib/queries'
import {whatsappHref} from '../../lib/contact'

const groups = await getWhatsappGroups()
const pages = await getCommunityPages()
const settings = await getSiteSettings()
const teamPhone = settings?.phone ?? '0542473799'
const teamWhatsapp = whatsappHref(teamPhone, teamPhone)
const dueDate = groups.filter((g: WhatsappGroup) => g.cohort === 'due-date')
const topic = groups.filter((g: WhatsappGroup) => g.cohort === 'topic')
const sections = [
  {title: 'לפי תאריך לידה', groups: dueDate},
  {title: 'לפי נושא', groups: topic},
]
const hasGroups = groups.length > 0
---
<Base title="קהילה — קבוצות וואטסאפ — שבט אמהות" description="קבוצות וואטסאפ לאמהות, לפי תאריך לידה ולפי נושא. קבוצות לנשים בלבד.">
  <section class="wrap">
    <h1>קהילה</h1>
    <p>קבוצות וואטסאפ לתמיכה, שיתוף וליווי לאורך הדרך.</p>
    <p class="note">קבוצות לנשים בלבד.</p>

    {!hasGroups && <p class="empty">אין קבוצות עדיין</p>}

    {hasGroups &&
      sections.map((section) =>
        section.groups.length > 0 ? (
          <div class="section">
            <h2>{section.title}</h2>
            <div class="grid">
              {section.groups.map((g: WhatsappGroup) => (
                <article class="card community-card">
                  <h3>{g.name}</h3>
                  {g.moderator && <p class="mod">מנחה: {g.moderator}</p>}
                  {g.guidelines && <p class="guidelines">{g.guidelines}</p>}
                  {g.inviteUrl && (
                    <a class="btn btn-wa" href={g.inviteUrl} target="_blank" rel="noopener noreferrer">
                      הצטרפו
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        ) : null,
      )}
  </section>

  {pages.length > 0 && (
    <section class="wrap community-pages">
      <h2>מפגשי קהילה וסדנאות</h2>
      <div class="grid">
        {pages.map((page: CommunityPage) => (
          <article class="card community-card">
            {page.image && <img src={`${page.image}?w=420&h=260&fit=crop`} alt={page.title} loading="lazy" />}
            <h3><a href={`/community/${page.slug}/`}>{page.title}</a></h3>
            {page.excerpt && <p>{page.excerpt}</p>}
            <a class="more" href={`/community/${page.slug}/`}>לפרטים נוספים ←</a>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="community-signup wrap">
    <h2>הצטרפות לקהילה</h2>
    <p>לא מצאתן קבוצה מתאימה? השאירו פרטים ונחבר אתכן. <span class="note">נשים בלבד</span></p>
    {teamWhatsapp && <a class="btn btn-wa" href={teamWhatsapp}>פנייה בוואטסאפ</a>}
    <form name="community-signup" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" class="netlify-form">
      <input type="hidden" name="form-name" value="community-signup" />
      <p hidden><label>אל תמלאי שדה זה: <input name="bot-field" /></label></p>
      <div class="form-row">
        <label for="cs-name">שם מלא *</label>
        <input id="cs-name" name="name" type="text" required autocomplete="name" />
      </div>
      <div class="form-row">
        <label for="cs-phone">טלפון *</label>
        <input id="cs-phone" name="phone" type="tel" required autocomplete="tel" />
      </div>
      <div class="form-row">
        <label for="cs-email">דואר אלקטרוני *</label>
        <input id="cs-email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="form-row">
        <label for="cs-due">תאריך לידה משוער (dueDate)</label>
        <input id="cs-due" name="dueDate" type="month" />
      </div>
      <div class="form-row form-row--check">
        <label>
          <input type="checkbox" name="consent" required />
          קראתי את <a href="/privacy/" target="_blank">מדיניות הפרטיות</a> ואני מסכימה.
        </label>
      </div>
      <button type="submit" class="btn">שלחי</button>
    </form>
  </section>

  <style>
    .note { display:inline-block; background:var(--peach-soft); color:var(--brand); border-radius:999px; padding:.2rem .9rem; font-weight:600; font-size:.9rem; }
    .empty { margin-top:2rem; color:var(--muted); font-size:1.1rem; }
    .section { margin-top:2.5rem; }
    .section h2 { margin-bottom:1rem; }
    .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1.2rem; }
    .community-signup { margin-top:3rem; padding-top:2rem; border-top:1px solid var(--line); }
    .community-pages { margin-top:3rem; }
    .community-card img { width:100%; aspect-ratio:16/10; object-fit:cover; border-radius:18px; margin-bottom:.8rem; }
    .netlify-form { display:flex; flex-direction:column; gap:.9rem; max-width:460px; margin-top:1.2rem; }
    .form-row { display:flex; flex-direction:column; gap:.3rem; }
    .form-row label { font-weight:600; font-size:.9rem; }
    .form-row input { border:1px solid var(--line); border-radius:8px; padding:.5rem .7rem; font:inherit; background:var(--surface); width:100%; box-sizing:border-box; }
    .form-row input:focus-visible { outline:2px solid var(--brand); outline-offset:1px; }
    .form-row--check label { display:flex; gap:.5rem; align-items:flex-start; font-weight:400; }
    .form-row--check input { width:auto; flex-shrink:0; margin-top:.2rem; }
  </style>
</Base>
