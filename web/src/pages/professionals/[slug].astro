---
import PortableText from "../../components/PortableText.astro";
import Base from "../../layouts/Base.astro";
import { getProfessionalDetails, type PractitionerDetailWithSlug } from "../../lib/queries";

export async function getStaticPaths() {
	const pros = await getProfessionalDetails();
	return pros.map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const d = Astro.props.doc as PractitionerDetailWithSlug;

function embed(url?: string): string | null {
	if (!url) return null;
	const yt = url.match(/(?:youtu\.be\/|v=)([\w-]{11})/);
	if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
	const vm = url.match(/vimeo\.com\/(\d+)/);
	if (vm) return `https://player.vimeo.com/video/${vm[1]}`;
	return null;
}
const video = embed(d.videoUrl);
const wa = d.whatsapp ? `https://wa.me/${String(d.whatsapp).replace(/\D/g, "")}` : null;
const tints = ["t-peach", "t-mint", "t-sky", "t-gold"];
const tags = [...(d.fields ?? []), ...(d.regions ?? [])];
const hasBio = (d.bio?.length ?? 0) > 0;
const hasServices = (d.services?.length ?? 0) > 0;
const hasFaq = (d.faq?.length ?? 0) > 0;
const hasReviews = (d.testimonials?.length ?? 0) > 0;
const hasGallery = (d.gallery?.length ?? 0) > 0;
---
<Base title={`${d.name} — אשת מקצוע | שבט אמהות`} description={d.title ?? d.name}>
	<header class="phead">
		<div class="wrap phead-inner">
			{
				d.photoUrl ? (
					<img class="avatar-lg" src={`${d.photoUrl}?w=240&h=240&fit=crop`} alt={d.name} />
				) : (
					<span class="avatar-lg ph">{d.name.charAt(0)}</span>
				)
			}
			<div>
				<h1>{d.name}</h1>
				{d.title && <p class="role">{d.title}</p>}
				<div class="tags">
					{tags.map((t, i) => <span class={`chip ${tints[i % tints.length]}`}>{t}</span>)}
				</div>
				{wa && <a class="btn btn-wa" href={wa}>פנייה בוואטסאפ</a>}
			</div>
		</div>
	</header>

	<article class="profile wrap">
		{
			video && (
				<div class="video">
					<iframe
						src={video}
						title="וידאו"
						loading="lazy"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen
					/>
				</div>
			)
		}

		{hasBio && <section><h2>קצת עליי</h2><PortableText blocks={d.bio} /></section>}
		{hasServices && <section><h2>מה כולל הליווי</h2><PortableText blocks={d.services} /></section>}

		{
			(d.credentials?.length ?? 0) > 0 && (
				<section>
					<h2>הסמכות</h2>
					<div class="tags">{d.credentials?.map((c) => <span class="chip t-mint">{c}</span>)}</div>
				</section>
			)
		}

		{
			hasGallery && (
				<section>
					<h2>גלריה</h2>
					<div class="gallery">
						{d.gallery?.map((g) => <img src={`${g}?w=400&h=400&fit=crop`} alt="" loading="lazy" />)}
					</div>
				</section>
			)
		}

		{
			hasReviews && (
				<section class="reviews">
					<h2>ממליצות</h2>
					{d.testimonials?.map((t) => (
						<blockquote>“{t.quote}”<cite>— {t.author}</cite></blockquote>
					))}
				</section>
			)
		}

		{
			hasFaq && (
				<section class="faq">
					<h2>שאלות ותשובות</h2>
					{d.faq?.map((f) => (
						<details>
							<summary>{f.q}</summary>
							<p>{f.a}</p>
						</details>
					))}
				</section>
			)
		}

		{
			(d.phone || d.email || d.instagram) && (
				<section class="contact">
					<h2>יצירת קשר</h2>
					<div class="contact-links">
						{d.phone && <a href={`tel:${d.phone}`}>{d.phone}</a>}
						{d.email && <a href={`mailto:${d.email}`}>{d.email}</a>}
						{d.instagram && <a href={d.instagram}>Instagram</a>}
					</div>
				</section>
			)
		}
	</article>

	{wa && <a class="btn btn-wa sticky-cta" href={wa}>פנייה בוואטסאפ</a>}

	<style>
		.phead {
			background: linear-gradient(160deg, var(--peach-soft), var(--peach));
			padding-block: clamp(2rem, 6vw, 3.5rem);
		}
		.phead-inner {
			display: flex;
			gap: 1.5rem;
			align-items: center;
			flex-wrap: wrap;
		}
		.avatar-lg {
			width: 120px;
			height: 120px;
			border-radius: 50%;
			object-fit: cover;
			flex: none;
			box-shadow: 0 10px 24px -12px rgba(146, 0, 59, 0.5);
		}
		.avatar-lg.ph {
			display: flex;
			align-items: center;
			justify-content: center;
			background: #fff;
			color: var(--brand);
			font-family: var(--display);
			font-size: 3.5rem;
		}
		.phead h1 {
			margin: 0;
		}
		.role {
			margin: 0.2rem 0 0.8rem;
			color: var(--brand-deep);
			font-weight: 600;
		}
		.tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.4rem;
			margin-bottom: 1rem;
		}
		.profile {
			padding-block: 2rem 6rem;
			max-width: 760px;
			display: flex;
			flex-direction: column;
			gap: 2rem;
		}
		.profile h2 {
			font-size: 1.8rem;
			margin: 0 0 0.6rem;
		}
		.video {
			position: relative;
			aspect-ratio: 16/9;
			border-radius: 16px;
			overflow: hidden;
		}
		.video iframe {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			border: 0;
		}
		.gallery {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
			gap: 0.6rem;
		}
		.gallery img {
			width: 100%;
			aspect-ratio: 1;
			object-fit: cover;
			border-radius: 12px;
		}
		.reviews {
			display: flex;
			flex-direction: column;
			gap: 1rem;
		}
		.reviews blockquote {
			background: #fff;
			border: 1px solid var(--line);
			border-radius: 14px;
			padding: 1.1rem 1.3rem;
			margin: 0;
			font-style: italic;
		}
		.reviews cite {
			display: block;
			margin-top: 0.5rem;
			color: var(--muted);
			font-style: normal;
			font-weight: 600;
		}
		.faq details {
			background: #fff;
			border: 1px solid var(--line);
			border-radius: 12px;
			padding: 0.8rem 1.1rem;
			margin-bottom: 0.6rem;
		}
		.faq summary {
			font-weight: 700;
			cursor: pointer;
			color: var(--ink);
		}
		.contact-links {
			display: flex;
			gap: 1.2rem;
			flex-wrap: wrap;
		}
		.contact-links a {
			font-weight: 600;
		}
		.sticky-cta {
			position: fixed;
			inset-inline: 1rem;
			bottom: 1rem;
			text-align: center;
			z-index: 40;
			box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.4);
		}
		@media (min-width: 700px) {
			.sticky-cta {
				inset-inline: auto;
				inset-inline-end: 2rem;
			}
		}
	</style>
</Base>
