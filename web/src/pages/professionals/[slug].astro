---
import Base from '../../layouts/Base.astro'
import {getProfessionalSlugs, getPractitioner} from '../../lib/queries'

export async function getStaticPaths() {
  const slugs: string[] = await getProfessionalSlugs()
  return slugs.map((slug) => ({params: {slug}}))
}

const {slug} = Astro.params
const d = await getPractitioner(slug!)

// YouTube/Vimeo → embeddable url
function embed(url?: string) {
  if (!url) return null
  const yt = url.match(/(?:youtu\.be\/|v=)([\w-]{11})/)
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`
  const vm = url.match(/vimeo\.com\/(\d+)/)
  if (vm) return `https://player.vimeo.com/video/${vm[1]}`
  return null
}
const video = embed(d?.videoUrl)
const wa = d?.whatsapp ? `https://wa.me/${String(d.whatsapp).replace(/\D/g, '')}` : null
---
<Base title={`${d?.name} — איש מקצוע | שבט אמהות`} description={d?.title}>
  <article class="profile wrap">
    {video && (
      <div class="video"><iframe src={video} title="וידאו" loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen></iframe></div>
    )}
    <header class="phead">
      {d?.photoUrl && <img class="avatar" src={`${d.photoUrl}?w=160&h=160&fit=crop`} alt={d.name} />}
      <div>
        <h1>{d?.name}</h1>
        <p class="title">{d?.title}</p>
        <div class="tags">
          {(d?.fields || []).map((f: string) => <span class="chip">{f}</span>)}
          {(d?.regions || []).map((r: string) => <span class="chip">{r}</span>)}
        </div>
      </div>
    </header>

    {(d?.testimonials?.length ?? 0) > 0 && (
      <section class="reviews">
        {d?.testimonials?.map((t) => (
          <blockquote>“{t.quote}” <cite>— {t.author}</cite></blockquote>
        ))}
      </section>
    )}

    {/* TODO: embed Rav-Messer (Responder) contact form here via siteSettings */}
  </article>

  {wa && <a class="btn btn-wa sticky-cta" href={wa}>פנייה בוואטסאפ</a>}

  <style>
    .profile { padding-block: 1.5rem 6rem; }
    .video { position:relative; aspect-ratio:16/9; border-radius:16px; overflow:hidden; margin-bottom:1.5rem; }
    .video iframe { position:absolute; inset:0; width:100%; height:100%; border:0; }
    .phead { display:flex; gap:1.2rem; align-items:center; flex-wrap:wrap; }
    .avatar { width:96px; height:96px; border-radius:50%; object-fit:cover; }
    .title { color:var(--muted); margin:.2rem 0; }
    .tags { display:flex; flex-wrap:wrap; gap:.4rem; }
    .reviews { margin-top:2rem; display:grid; gap:1rem; }
    .reviews blockquote { background:#fff; border:1px solid var(--line); border-radius:12px; padding:1rem 1.2rem; margin:0; font-style:italic; }
    .sticky-cta { position:fixed; inset-inline:1rem; bottom:1rem; text-align:center; z-index:40; box-shadow:0 8px 24px -8px rgba(0,0,0,.4); }
    @media(min-width:700px){ .sticky-cta{ inset-inline:auto; inset-inline-end:2rem; } }
  </style>
</Base>
