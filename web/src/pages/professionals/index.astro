---
import Base from '../../layouts/Base.astro'
import {getProfessionals} from '../../lib/queries'
import {instagramHref, mailtoHref, telHref, whatsappHref} from '../../lib/contact'

const pros = (await getProfessionals()).map((p) => ({
  ...p,
  whatsappUrl: whatsappHref(p.whatsapp, p.phone),
  phoneUrl: telHref(p.phone),
  emailUrl: mailtoHref(p.email),
  instagramUrl: instagramHref(p.instagram),
}))
const fields = [...new Set(pros.flatMap((p) => p.fields ?? []))].sort()
const regions = [...new Set(pros.flatMap((p) => p.regions ?? []))].sort()
const langs = [...new Set(pros.flatMap((p) => p.languages ?? []))].sort()
---
<Base title="חיפוש נשות מקצוע — שבט אמהות" description="יועצות הנקה, מעסות, רפלקסולוגיות ועוד — לפי תחום ומיקום.">
  <section class="wrap">
    <h1>נבחרת היועצות של שבט אמהות</h1>
    <p>יועצות הנקה, מטפלות, מדריכות ונשות מקצוע — סינון לפי תחום ומיקום.</p>

    <form class="filter-panel" id="pro-filters">
      <label>תחום טיפול
        <select name="field"><option value="">הכול</option>{fields.map((x: string) => <option>{x}</option>)}</select>
      </label>
      <label>אזור
        <select name="region"><option value="">הכול</option>{regions.map((x: string) => <option>{x}</option>)}</select>
      </label>
      <label>שפה
        <select name="lang"><option value="">הכול</option>{langs.map((x: string) => <option>{x}</option>)}</select>
      </label>
      <button type="button" id="reset">ניקוי</button>
    </form>

    <p id="count">{pros.length} נשות מקצוע</p>
    <div class="grid" id="results">
      {pros.map((p) => (
        <article class="card directory-card doula-card">
          {p.photo && <a class="card-media" href={`/professionals/${p.slug}/`}><img src={`${p.photo}?w=480&h=360&fit=crop`} alt={p.name} loading="lazy" /></a>}
          <div class="card-body">
            <h3><a href={`/professionals/${p.slug}/`}>{p.name}</a></h3>
            {p.title && <p class="card-title">{p.title}</p>}
            <div class="tags">{[...(p.fields ?? []), ...(p.regions ?? [])].slice(0, 3).map((t) => <span class="chip">{t}</span>)}</div>
            <div class="card-actions"><a class="more" href={`/professionals/${p.slug}/`}>לפרטים נוספים ←</a></div>
            <div class="card-actions contact-links">
              {p.whatsappUrl && <a class="btn btn-wa" href={p.whatsappUrl}>וואטסאפ</a>}
              {p.phoneUrl && <a class="more" href={p.phoneUrl}>טלפון</a>}
              {p.emailUrl && <a class="more" href={p.emailUrl}>אימייל</a>}
              {p.instagramUrl && <a class="more" href={p.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script type="application/json" id="data" is:inline set:html={JSON.stringify(pros)}></script>
  <script>
    interface Row {
      slug: string; name: string; title?: string; photo?: string; whatsappUrl?: string; phoneUrl?: string; emailUrl?: string; instagramUrl?: string;
      fields?: string[]; regions?: string[]; languages?: string[];
    }
    const dataEl = document.getElementById("data");
    const form = document.getElementById("pro-filters") as HTMLFormElement | null;
    const out = document.getElementById("results");
    const count = document.getElementById("count");
    const reset = document.getElementById("reset");

    if (dataEl && form && out && count) {
      const data: Row[] = JSON.parse(dataEl.textContent ?? "[]");
      const esc = (s: string): string =>
        s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] ?? c);
      const card = (p: Row): string => {
        const name = esc(p.name);
        const tags = [...(p.fields ?? []), ...(p.regions ?? [])]
          .slice(0, 3)
          .map((t) => `<span class="chip">${esc(t)}</span>`)
          .join("");
        const href = `/professionals/${encodeURIComponent(p.slug)}/`;
        const wa = p.whatsappUrl
          ? `<a class="btn btn-wa" href="${esc(p.whatsappUrl)}">וואטסאפ</a>`
          : "";
        const phone = p.phoneUrl ? `<a class="more" href="${esc(p.phoneUrl)}">טלפון</a>` : "";
        const email = p.emailUrl ? `<a class="more" href="${esc(p.emailUrl)}">אימייל</a>` : "";
        const instagram = p.instagramUrl ? `<a class="more" href="${esc(p.instagramUrl)}" target="_blank" rel="noopener noreferrer">Instagram</a>` : "";
        const media = p.photo
          ? `<a class="card-media" href="${href}"><img src="${encodeURI(p.photo)}?w=480&h=360&fit=crop" alt="${name}" loading="lazy"></a>`
          : "";
        const title = p.title ? `<p class="card-title">${esc(p.title)}</p>` : "";
        return `<article class="card directory-card doula-card">
          ${media}
          <div class="card-body">
            <h3><a href="${href}">${name}</a></h3>
            ${title}
            <div class="tags">${tags}</div>
            <div class="card-actions"><a class="more" href="${href}">לפרטים נוספים ←</a></div>
            <div class="card-actions contact-links">${wa}${phone}${email}${instagram}</div>
          </div>
        </article>`;
      };
      const apply = (): void => {
        const f = new FormData(form);
        const fld = f.get("field");
        const reg = f.get("region");
        const lang = f.get("lang");
        const res = data.filter(
          (p) =>
            (!fld || (p.fields ?? []).includes(fld as string)) &&
            (!reg || (p.regions ?? []).includes(reg as string)) &&
            (!lang || (p.languages ?? []).includes(lang as string)),
        );
        out.innerHTML = res.map(card).join("");
        count.textContent = `${res.length} נשות מקצוע`;
      };
      form.addEventListener("input", apply);
      reset?.addEventListener("click", () => {
        HTMLFormElement.prototype.reset.call(form);
        apply();
      });
      apply();
    }
  </script>

  <style>
    #count { color:var(--muted); font-weight:600; margin:.5rem 0 1.2rem; }
  </style>
</Base>
