---
import Base from '../../layouts/Base.astro'
import LegacyContent from '../../components/LegacyContent.astro'
import {getArticle, getArticleSlugs} from '../../lib/queries'

export async function getStaticPaths() {
  const slugs: string[] = await getArticleSlugs()
  return slugs.map((slug) => ({params: {slug}}))
}

const {slug} = Astro.params
const a = await getArticle(slug!)

const blocks = Array.isArray(a?.body) ? a!.body : []
const registrationText = `${a?.title ?? ''} ${a?.excerpt ?? ''} ${a?.sourceHtml ?? ''}`
const showRegistration = /הרשמה|להרשמה|סדנ|זום/.test(registrationText)
---
<Base title={a ? `${a.title} — שבט אמהות` : 'מאמר — שבט אמהות'} description={a?.excerpt}>
  <article class="article-shell wrap">
    {a ? (
      <>
        {a.cover && (
          <img class="cover" src={`${a.cover}?w=1200&h=600&fit=crop`} alt={a.title} />
        )}
        <h1>{a.title}</h1>

        {a.videoUrl && <a class="btn btn-outline" href={a.videoUrl} target="_blank" rel="noopener noreferrer">צפייה בוידאו</a>}

        <LegacyContent html={a.sourceHtml} blocks={blocks} />
      </>
    ) : (
      <p class="empty-state">אין מאמרים עדיין</p>
    )}
  </article>

  {showRegistration && <section class="workshop-registration wrap">
    <h2>הרשמה לסדנא / קורס</h2>
    <form name="workshop-registration" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" class="netlify-form">
      <input type="hidden" name="form-name" value="workshop-registration" />
      <input type="hidden" name="article" value={a?.title ?? ''} />
      <p hidden><label>אל תמלאי שדה זה: <input name="bot-field" /></label></p>
      <div class="form-row">
        <label for="wr-name">שם מלא *</label>
        <input id="wr-name" name="name" type="text" required autocomplete="name" />
      </div>
      <div class="form-row">
        <label for="wr-phone">טלפון *</label>
        <input id="wr-phone" name="phone" type="tel" required autocomplete="tel" />
      </div>
      <div class="form-row">
        <label for="wr-email">דואר אלקטרוני</label>
        <input id="wr-email" name="email" type="email" autocomplete="email" />
      </div>
      <div class="form-row form-row--check">
        <label>
          <input type="checkbox" name="consent" required />
          קראתי את <a href="/privacy/" target="_blank">מדיניות הפרטיות</a> ואני מסכימה.
        </label>
      </div>
      <button type="submit" class="btn">שלחי הרשמה</button>
    </form>
  </section>}

  <style>
    .article-shell { max-width: 760px; }
    .cover { aspect-ratio:2/1; margin-bottom:1.5rem; }
    .article-body { margin-top:1.5rem; }
    .workshop-registration { margin-top:2.5rem; padding-top:2rem; border-top:1px solid var(--line); max-width:760px; }
    .netlify-form { display:flex; flex-direction:column; gap:.9rem; max-width:460px; margin-top:1.2rem; }
    .form-row { display:flex; flex-direction:column; gap:.3rem; }
    .form-row label { font-weight:600; font-size:.9rem; }
    .form-row input { border:1px solid var(--line); border-radius:8px; padding:.5rem .7rem; font:inherit; background:var(--surface); width:100%; box-sizing:border-box; }
    .form-row input:focus-visible { outline:2px solid var(--brand); outline-offset:1px; }
    .form-row--check label { display:flex; gap:.5rem; align-items:flex-start; font-weight:400; }
    .form-row--check input { width:auto; flex-shrink:0; margin-top:.2rem; }
  </style>
</Base>
