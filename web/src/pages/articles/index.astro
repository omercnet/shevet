---
import Base from '../../layouts/Base.astro'
import {getArticles} from '../../lib/queries'

const articles = await getArticles()

// Category filter — value matches Sanity `category`, label is Hebrew.
const CATEGORIES = [
  {value: 'pregnancy', label: 'הריון'},
  {value: 'birth', label: 'לידה'},
  {value: 'breastfeeding', label: 'הנקה'},
  {value: 'infant', label: 'תינוקות'},
  {value: 'natural-birth', label: 'לידה טבעית'},
  {value: 'parenting', label: 'הורות'},
  {value: 'anxiety', label: 'חרדה'},
] as const
---
<Base title="מאמרים — שבט אמהות" description="מאמרים על הריון, לידה, הנקה, תינוקות, הורות ועוד.">
  <section class="wrap">
    <h1>מאמרים</h1>

    {articles.length === 0 ? (
      <p class="empty">אין מאמרים עדיין</p>
    ) : (
      <>
        <form class="filters" id="article-filters">
          <label>קטגוריה
            <select name="category"><option value="">הכול</option>
              {CATEGORIES.map((c) => <option value={c.value}>{c.label}</option>)}
            </select>
          </label>
          <button type="button" id="reset">ניקוי</button>
        </form>

        <p id="count"></p>
        <div class="grid" id="results"></div>
      </>
    )}
  </section>

  {articles.length > 0 && (
    <script type="application/json" id="data" is:inline set:html={JSON.stringify(articles)}></script>
  )}
  {articles.length > 0 && (
    <script type="application/json" id="labels" is:inline set:html={JSON.stringify(CATEGORIES)}></script>
  )}
  <script>
    interface Row {
      slug: string; title: string; type?: string; category?: string;
      excerpt?: string; cover?: string;
    }
    interface Category { value: string; label: string; }
    const dataEl = document.getElementById("data");
    const labelsEl = document.getElementById("labels");
    const form = document.getElementById("article-filters") as HTMLFormElement | null;
    const out = document.getElementById("results");
    const count = document.getElementById("count");
    const reset = document.getElementById("reset");

    if (dataEl && labelsEl && form && out && count) {
      const data: Row[] = JSON.parse(dataEl.textContent ?? "[]");
      const labels: Category[] = JSON.parse(labelsEl.textContent ?? "[]");
      const labelFor = (value?: string): string =>
        labels.find((c) => c.value === value)?.label ?? "";
      const escapeHtml = (s: string): string =>
        s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
      const bg = ["bg-peach", "bg-mint", "bg-sky", "bg-gold"];
      const card = (a: Row, i: number): string => {
        const cat = labelFor(a.category);
        const chip = cat ? `<span class="chip">${escapeHtml(cat)}</span>` : "";
        const href = `/articles/${encodeURIComponent(a.slug)}/`;
        const media = a.cover
          ? `<a class="a-media" href="${href}"><img src="${encodeURI(a.cover)}?w=480&h=270&fit=crop" alt="${escapeHtml(a.title)}" loading="lazy"></a>`
          : `<a class="a-media ${bg[i % bg.length]}" href="${href}"><span class="a-ph">${escapeHtml(cat || "שבט אמהות")}</span></a>`;
        const excerpt = a.excerpt ? `<p class="excerpt clamp-3">${escapeHtml(a.excerpt)}</p>` : "";
        return `<article class="card a-card">${media}<div class="card-body"><div class="tags">${chip}</div><h3><a href="${href}">${escapeHtml(a.title)}</a></h3>${excerpt}<div class="card-actions"><a class="more" href="${href}">קרא עוד ←</a></div></div></article>`;
      };
      const apply = (): void => {
        const f = new FormData(form);
        const category = f.get("category");
        const res = data.filter((a) => !category || a.category === (category as string));
        out.innerHTML = res.map(card).join("");
        count.textContent = `${res.length} מאמרים`;
      };
      form.addEventListener("input", apply);
      reset?.addEventListener("click", () => {
        form.reset();
        apply();
      });
      apply();
    }
  </script>

  <style>
    .filters { display:flex; gap:1rem 1.2rem; flex-wrap:wrap; align-items:end; background:linear-gradient(160deg,var(--peach-soft),var(--peach)); padding:1.5rem; border-radius:18px; margin:1.5rem 0; }
    .filters label { display:flex; flex-direction:column; font-size:.8rem; gap:.35rem; color:var(--brand); font-weight:700; }
    .filters select { padding:.6rem .7rem; border:1px solid var(--line); border-radius:10px; font-family:inherit; background:#fff; min-width:11ch; }
    .filters select:focus { outline:2px solid var(--brand); outline-offset:1px; }
    .filters button { align-self:end; background:#fff; border:1px solid var(--brand); color:var(--brand); border-radius:999px; padding:.6rem 1.2rem; cursor:pointer; font-weight:700; }
    .filters button:hover { background:var(--brand); color:#fff; }
    #count { color:var(--muted); font-weight:600; margin:.5rem 0 1.2rem; }
    .empty { color:var(--muted); margin:2rem 0; }
  </style>
</Base>
