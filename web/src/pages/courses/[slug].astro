---
import Base from "../../layouts/Base.astro";
import LegacyContent from "../../components/LegacyContent.astro";
import { getSalePage, getSalePageSlugs } from "../../lib/queries";

export async function getStaticPaths() {
	const slugs = await getSalePageSlugs();
	return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const page = await getSalePage(slug!);

const ctaLabel = page?.ctaLabel ?? "לרכישה";
const meshulamUrl = page?.meshulamUrl;
---
<Base title={`${page?.title ?? ""} | שבט אמהות`} description={page?.title}>
	<article class="sale-hero wrap">
		<h1>{page?.title}</h1>
		{page?.image && <img class="cover" src={page.image} alt={page?.title ?? ""} />}
		<LegacyContent html={page?.sourceHtml} blocks={page?.blurb ?? []} />
		{(page?.dateText || page?.location || page?.cost || page?.presenter) && (
			<div class="tags">
				{page?.presenter && <span class="chip">{page.presenter}</span>}
				{page?.dateText && <span class="chip">{page.dateText}</span>}
				{page?.location && <span class="chip">{page.location}</span>}
				{page?.cost && <span class="chip">{page.cost}</span>}
			</div>
		)}
		{meshulamUrl && (
			<a class="btn cta" href={meshulamUrl} target="_blank" rel="noopener noreferrer">
				{ctaLabel}
			</a>
		)}
		{!meshulamUrl && page?.formEmbedHtml && (
			<a class="btn cta" href={page.formEmbedHtml} target="_blank" rel="noopener noreferrer">{ctaLabel}</a>
		)}
	</article>

	<style>
		.sale-hero { max-width: 900px; }
		.cover { width: 100%; border-radius: 16px; margin-block: 1rem 1.5rem; }
		.cta { margin-top: 2rem; font-size: 1.1rem; padding: 0.9rem 2rem; }
	</style>
</Base>
