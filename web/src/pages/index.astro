---
import ZigZag from "../components/ZigZag.astro";
import Base from "../layouts/Base.astro";
import { getArticles, getBenefits, getDoulas, getProfessionals } from "../lib/queries";

const [doulas, professionals, articles, benefits] = await Promise.all([
	getDoulas(),
	getProfessionals(),
	getArticles(),
	getBenefits(),
]);

const featuredPeople = [
	...doulas.filter((d) => d.photo).slice(0, 3).map((person) => ({ ...person, basePath: "/doulas" })),
	...professionals.filter((p) => p.photo).slice(0, 3).map((person) => ({ ...person, basePath: "/professionals" })),
];
const featuredArticles = articles.slice(0, 3);
const featuredBenefits = benefits.slice(0, 3);

const pillars = [
	{ href: "/doulas/", title: "מאגר דולות", body: "חיפוש מדויק לפי בית חולים, סגנון ליווי ותקציב.", tint: "peach" },
	{ href: "/professionals/", title: "נשות מקצוע", body: "יועצות הנקה, מעסות, רפלקסולוגיות ועוד — לפי תחום ומיקום.", tint: "mint" },
	{ href: "/articles/", title: "מאמרים וסדנאות", body: "ידע מקצועי להריון, ללידה ולתקופה שאחריה.", tint: "sky" },
	{ href: "/benefits/", title: "מועדון הטבות", body: "קופונים והנחות מעשרות עסקים נבחרים.", tint: "gold" },
];
---
<Base title="שבט אמהות" description="הקהילה שלך להריון וללידה — דולות, נשות מקצוע, תוכן והטבות.">
	<section class="hero hero-photo">
		<div class="wrap hero-inner">
			<div class="hero-copy">
				<p class="hero-eyebrow">שבט אמהות</p>
				<h1>הדולות הטובות בישראל מחכות לך אצלנו בשבט</h1>
			</div>
			<div class="hero-visual hero-badge" aria-hidden="true">
				<img class="hero-mark" src="/brand/old-mark.png" alt="" width="512" height="512" />
			</div>
		</div>
	</section>
	<ZigZag />

	<section class="section wrap">
		<div class="section-head">
			<p class="eyebrow">כל מה שצריך במקום אחד</p>
			<h2>הכול בשבט</h2>
			<p>ברוכה הבאה לבית של הדולות, היועצות, הידע וההטבות של שבט אמהות.</p>
		</div>
		<div class="grid pillars">
			{
				pillars.map((p) => (
					<a class:list={["card", "pillar", `tint-${p.tint}`]} href={p.href}>
						<h3>{p.title}</h3>
						<p>{p.body}</p>
						<span class="pillar-go">לכניסה ←</span>
					</a>
				))
			}
		</div>
	</section>

	<section class="section wrap highlight-section">
		<div class="section-head">
			<p class="eyebrow">הבית של הדולות הטובות בישראל</p>
			<h2>נבחרת דולות ונשות מקצוע</h2>
			<p>הכירי את הדולות והיועצות של השבט, לפי תחום, אזור ובית חולים.</p>
		</div>
		<div class="grid mini-grid">
			{featuredPeople.slice(0, 6).map((p) => (
				<a class="card mini-card doula-card" href={`${p.basePath}/${p.slug}/`}>
					{p.photo && <img src={`${p.photo}?w=360&h=260&fit=crop`} alt={p.name} loading="lazy" />}
					<h3>{p.name}</h3>
					{p.title && <p>{p.title}</p>}
				</a>
			))}
		</div>
	</section>

	<section class="section wrap highlight-section">
		<div class="section-head">
			<p class="eyebrow">ידע והטבות</p>
			<h2>תוכן שימושי להריון, לידה ואחרי</h2>
		</div>
		<div class="grid mini-grid">
			{featuredArticles.map((a) => (
				<a class="card mini-card" href={`/articles/${a.slug}/`}>
					{a.cover && <img src={`${a.cover}?w=360&h=220&fit=crop`} alt={a.title} loading="lazy" />}
					<h3>{a.title}</h3>
					{a.excerpt && <p>{a.excerpt}</p>}
				</a>
			))}
			{featuredBenefits.map((b) => (
				<a class="card mini-card" href={b.slug ? `/benefits/${b.slug}/` : "/benefits/"}>
					{b.logo && <img src={`${b.logo}?w=220&h=120&fit=max`} alt={b.partner} loading="lazy" />}
					<h3>{b.partner}</h3>
					{b.discount && <p>{b.discount}</p>}
				</a>
			))}
		</div>
	</section>

	<section class="section wrap join-section">
		<div class="section-head">
			<p class="eyebrow">את אשת מקצוע בתחום ההריון ההורות והלידה?</p>
			<h2>בואי להצטרף לשבט</h2>
			<p>אם את דולה או אשת מקצוע ורוצה להופיע במאגר, התחילי כאן.</p>
		</div>
		<a class="btn" href="/doulas/join/">להצטרפות לנבחרת</a>
	</section>

	<style>
		.hero {
			position: relative;
			overflow: hidden;
			background:
				linear-gradient(rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.44)),
				url("/brand/old-home-hero.avif") center 36% / cover;
			min-height: calc(100svh - 4.4rem);
			padding-block: clamp(2.5rem, 8vw, 4rem);
		}
		.hero::before {
			content: "";
			position: absolute;
			inset: 0;
			background: linear-gradient(180deg, rgba(0, 0, 0, 0.2), transparent 34%, rgba(0, 0, 0, 0.18));
			pointer-events: none;
		}
		.hero-inner {
			position: relative;
			z-index: 1;
			display: flex;
			max-width: 1320px;
			min-height: calc(100svh - 9rem);
			flex-direction: column;
			align-items: center;
			justify-content: flex-start;
			gap: clamp(1.1rem, 3vw, 2rem);
			padding-top: clamp(7rem, 18vh, 10rem);
			text-align: center;
		}
		.hero-copy {
			order: 1;
			color: var(--surface);
			text-align: center;
			text-shadow: 0 0.12em 0.28em rgba(0, 0, 0, 0.32);
		}
		.hero-eyebrow {
			font-family: var(--display);
			font-size: clamp(4rem, 9vw, 7.4rem);
			letter-spacing: 0.08em;
			font-weight: 700;
			color: var(--surface);
			margin: 0 0 0.2rem;
		}
		.hero h1 {
			font-size: clamp(2rem, 3.6vw, 3.4rem);
			color: var(--surface);
			margin: 0;
			text-wrap: balance;
		}
		.hero-visual {
			order: 2;
			position: relative;
			display: grid;
			width: clamp(10.5rem, 18vw, 13.5rem);
			aspect-ratio: 1;
			place-items: center;
			border-radius: 50%;
			background: rgba(255, 255, 255, 0.9);
			box-shadow: 0 14px 34px -26px rgba(0, 0, 0, 0.58);
		}
		.hero-visual::before,
		.hero-visual::after {
			content: "";
			position: absolute;
			border-radius: 50%;
			pointer-events: none;
		}
		.hero-visual::before {
			inset: 0;
		}
		.hero-visual::after {
			inset: 0;
		}
		.hero-badge {
			display: grid;
			place-items: center;
		}
		.hero-badge::after {
			content: "";
			position: absolute;
			inset: 0;
			border-radius: 50%;
		}
		.hero-mark {
			width: 100%;
			border-radius: 50%;
		}
		@media (max-width: 760px) {
			.hero-inner {
				min-height: calc(100svh - 8rem);
				padding-top: 4.4rem;
			}
			.hero-visual { width: clamp(9.5rem, 44vw, 11rem); }
			.hero-eyebrow {
				font-size: clamp(3.4rem, 17vw, 5rem);
				letter-spacing: 0.04em;
			}
			.hero h1 {
				font-size: clamp(1.5rem, 6vw, 2.2rem);
			}
		}
		.pillars {
			grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		}
		.pillar {
			position: relative;
			display: flex;
			flex-direction: column;
			padding: 1.6rem;
			text-decoration: none;
			color: var(--text);
			border-top: 5px solid var(--peach);
		}
		.pillar::before {
			content: "";
			position: absolute;
			inset-inline: 1.2rem auto;
			top: 1.1rem;
			width: 2.2rem;
			height: 0.35rem;
			border-radius: 999px;
			background: currentColor;
			opacity: 0.16;
		}
		.pillar.tint-peach {
			border-top-color: var(--apricot);
		}
		.pillar.tint-mint {
			border-top-color: var(--mint);
		}
		.pillar.tint-sky {
			border-top-color: var(--sky);
		}
		.pillar.tint-gold {
			border-top-color: var(--gold);
		}
		.pillar h3 {
			margin: 0 0 0.5rem;
			font-size: 1.5rem;
		}
		.pillar p {
			margin: 0 0 1rem;
			color: var(--muted);
			flex: 1;
		}
		.pillar-go {
			color: var(--brand);
			font-weight: 700;
		}
		.highlight-section { padding-top: 0; }
		.mini-card { display:block; text-decoration:none; color:var(--text); padding:1rem; }
		.mini-card img { width:100%; aspect-ratio:4/3; object-fit:cover; border-radius:18px; margin-bottom:.85rem; }
		.mini-card h3 { margin:.2rem 0 .45rem; }
		.mini-card p { margin:0; color:var(--muted); }
		.mini-card.doula-card { text-align:center; }
		.mini-card.doula-card img { width:62%; aspect-ratio:1/1; border-radius:50%; margin:0 auto .85rem; }
		.join-section { text-align:center; }
	</style>
</Base>
