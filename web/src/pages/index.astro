---
import ZigZag from "../components/ZigZag.astro";
import Base from "../layouts/Base.astro";

const pillars = [
	{ href: "/doulas/", title: "מאגר דולות", body: "חיפוש מדויק לפי בית חולים, סגנון ליווי ותקציב.", tint: "peach" },
	{ href: "/professionals/", title: "נשות מקצוע", body: "יועצות הנקה, מעסות, רפלקסולוגיות ועוד — לפי תחום ומיקום.", tint: "mint" },
	{ href: "/articles/", title: "מאמרים וסדנאות", body: "ידע מקצועי להריון, ללידה ולתקופה שאחריה.", tint: "sky" },
	{ href: "/benefits/", title: "מועדון הטבות", body: "קופונים והנחות מעשרות עסקים נבחרים.", tint: "gold" },
];
---
<Base title="שבט אמהות" description="הקהילה שלך להריון וללידה — דולות, נשות מקצוע, תוכן והטבות.">
	<section class="hero">
		<div class="wrap hero-inner">
			<div class="hero-copy">
				<p class="hero-eyebrow">קהילת ההריון והלידה</p>
				<h1>השבט שלך<br />בדרך ללידה שאת מובילה</h1>
				<p class="hero-sub">מצאי את הדולה או אשת המקצוע שמתאימה לך — חיפוש מדויק לפי מה שחשוב לך.</p>
				<div class="cta-row">
					<a class="btn" href="/doulas/">חיפוש דולות</a>
					<a class="btn btn-outline" href="/professionals/">חיפוש נשות מקצוע</a>
				</div>
			</div>
			<div class="hero-visual" aria-hidden="true">
				<div class="hero-badge"><img src="/brand/mark.png" alt="" width="220" height="220" /></div>
				<span class="hero-note note-one">דולות</span>
				<span class="hero-note note-two">קהילה</span>
				<span class="hero-note note-three">ידע</span>
			</div>
		</div>
	</section>
	<ZigZag />

	<section class="section wrap">
		<div class="section-head">
			<p class="eyebrow">כל מה שצריך במקום אחד</p>
			<h2>הכול בשבט</h2>
		</div>
		<div class="grid pillars">
			{
				pillars.map((p) => (
					<a class:list={["card", "pillar", `tint-${p.tint}`]} href={p.href}>
						<h3>{p.title}</h3>
						<p>{p.body}</p>
						<span class="pillar-go">לכניסה ←</span>
					</a>
				))
			}
		</div>
	</section>

	<style>
		.hero {
			position: relative;
			overflow: hidden;
			background:
				radial-gradient(circle at 18% 22%, rgba(205, 233, 202, 0.65), transparent 24%),
				radial-gradient(circle at 82% 18%, rgba(251, 207, 172, 0.8), transparent 28%),
				linear-gradient(145deg, var(--surface) 0%, var(--cream) 52%, var(--peach-soft) 100%);
			padding-block: clamp(3.5rem, 10vw, 6rem) clamp(2.5rem, 7vw, 4rem);
		}
		.hero::before {
			content: "";
			position: absolute;
			inset: 1.2rem clamp(1rem, 5vw, 4rem) auto;
			height: 0.35rem;
			border-radius: 999px;
			background: linear-gradient(90deg, var(--brand), var(--apricot), var(--mint), var(--sky), var(--gold));
			opacity: 0.68;
		}
		.hero-inner {
			display: grid;
			grid-template-columns: minmax(0, 1.1fr) minmax(250px, 0.9fr);
			align-items: center;
			gap: clamp(2rem, 6vw, 4rem);
		}
		.hero-copy {
			text-align: right;
		}
		.hero-eyebrow {
			text-transform: uppercase;
			letter-spacing: 0.24em;
			font-size: 0.8rem;
			font-weight: 700;
			color: var(--brand);
			margin: 0 0 1rem;
		}
		.hero h1 {
			font-size: clamp(3rem, 8vw, 5.6rem);
			margin: 0;
			text-wrap: balance;
		}
		.hero-sub {
			font-size: clamp(1.05rem, 2.4vw, 1.35rem);
			max-width: 42ch;
			margin: 1.2rem 0 0;
			color: var(--text);
		}
		.cta-row {
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
			justify-content: flex-start;
			margin-top: 2.2rem;
		}
		.hero-visual {
			position: relative;
			min-height: clamp(18rem, 36vw, 26rem);
			border-radius: 45% 55% 52% 48%;
			background:
				radial-gradient(circle, var(--surface) 0 34%, transparent 35%),
				radial-gradient(circle at 50% 50%, rgba(146, 0, 59, 0.12), transparent 54%),
				var(--peach-soft);
			box-shadow: 0 28px 70px -48px rgba(63, 34, 48, 0.8);
		}
		.hero-visual::before,
		.hero-visual::after {
			content: "";
			position: absolute;
			border-radius: 50%;
			pointer-events: none;
		}
		.hero-visual::before {
			inset: 8% 10% auto auto;
			width: 5.5rem;
			aspect-ratio: 1;
			background: var(--mint);
			opacity: 0.72;
		}
		.hero-visual::after {
			left: 10%;
			bottom: 10%;
			width: 7rem;
			aspect-ratio: 1;
			background: var(--sky);
			opacity: 0.58;
			filter: blur(1px);
		}
		.hero-badge {
			position: absolute;
			inset: 50% auto auto 50%;
			width: clamp(9rem, 22vw, 14rem);
			aspect-ratio: 1;
			transform: translate(-50%, -50%);
			display: grid;
			place-items: center;
			border-radius: 50%;
			background: var(--surface);
			box-shadow: 0 20px 44px -30px rgba(63, 34, 48, 0.9);
		}
		.hero-badge::after {
			content: "";
			position: absolute;
			inset: -0.65rem;
			border: 2px dashed var(--peach);
			border-radius: 50%;
			opacity: 0.9;
		}
		.hero-badge img {
			width: 68%;
		}
		.hero-note {
			position: absolute;
			border-radius: 999px;
			background: var(--surface);
			padding: 0.45rem 1rem;
			font-weight: 700;
			color: var(--brand);
			box-shadow: 0 14px 30px -24px rgba(63, 34, 48, 0.8);
		}
		.note-one {
			top: 18%;
			right: 6%;
			background: var(--mint);
			color: var(--ink);
		}
		.note-two {
			bottom: 18%;
			right: 12%;
			background: var(--sky);
			color: var(--ink);
		}
		.note-three {
			bottom: 26%;
			left: 6%;
			background: var(--gold);
			color: var(--ink);
		}
		@media (max-width: 760px) {
			.hero-inner {
				grid-template-columns: 1fr;
				text-align: center;
			}
			.hero-copy {
				text-align: center;
			}
			.hero-sub {
				margin-inline: auto;
			}
			.cta-row {
				justify-content: center;
			}
			.hero-visual {
				min-height: 15rem;
				max-width: 22rem;
				width: 100%;
				margin-inline: auto;
			}
		}
		.pillars {
			grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		}
		.pillar {
			position: relative;
			display: flex;
			flex-direction: column;
			padding: 1.6rem;
			text-decoration: none;
			color: var(--text);
			border-top: 5px solid var(--peach);
		}
		.pillar::before {
			content: "";
			position: absolute;
			inset-inline: 1.2rem auto;
			top: 1.1rem;
			width: 2.2rem;
			height: 0.35rem;
			border-radius: 999px;
			background: currentColor;
			opacity: 0.16;
		}
		.pillar.tint-peach {
			border-top-color: var(--apricot);
		}
		.pillar.tint-mint {
			border-top-color: var(--mint);
		}
		.pillar.tint-sky {
			border-top-color: var(--sky);
		}
		.pillar.tint-gold {
			border-top-color: var(--gold);
		}
		.pillar h3 {
			margin: 0 0 0.5rem;
			font-size: 1.5rem;
		}
		.pillar p {
			margin: 0 0 1rem;
			color: var(--muted);
			flex: 1;
		}
		.pillar-go {
			color: var(--brand);
			font-weight: 700;
		}
	</style>
</Base>
