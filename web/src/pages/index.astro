---
import ZigZag from "../components/ZigZag.astro";
import Base from "../layouts/Base.astro";

const pillars = [
	{ href: "/doulas/", title: "מאגר דולות", body: "חיפוש מדויק לפי בית חולים, סגנון ליווי ותקציב.", tint: "peach" },
	{ href: "/professionals/", title: "נשות מקצוע", body: "יועצות הנקה, מעסות, רפלקסולוגיות ועוד — לפי תחום ומיקום.", tint: "mint" },
	{ href: "/articles/", title: "מאמרים וסדנאות", body: "ידע מקצועי להריון, ללידה ולתקופה שאחריה.", tint: "sky" },
	{ href: "/benefits/", title: "מועדון הטבות", body: "קופונים והנחות מעשרות עסקים נבחרים.", tint: "gold" },
];
---
<Base title="שבט אמהות" description="הקהילה שלך להריון וללידה — דולות, נשות מקצוע, תוכן והטבות.">
	<section class="hero">
		<div class="wrap hero-inner">
			<p class="hero-eyebrow">קהילת ההריון והלידה</p>
			<h1>השבט שלך<br />בדרך ללידה שאת מובילה</h1>
			<p class="hero-sub">מצאי את הדולה או אשת המקצוע שמתאימה לך — חיפוש מדויק לפי מה שחשוב לך.</p>
			<div class="cta-row">
				<a class="btn" href="/doulas/">חיפוש דולות</a>
				<a class="btn btn-outline" href="/professionals/">חיפוש נשות מקצוע</a>
			</div>
		</div>
	</section>
	<ZigZag />

	<section class="section wrap">
		<div class="section-head">
			<p class="eyebrow">כל מה שצריך במקום אחד</p>
			<h2>הכול בשבט</h2>
		</div>
		<div class="grid pillars">
			{
				pillars.map((p) => (
					<a class:list={["card", "pillar", `tint-${p.tint}`]} href={p.href}>
						<h3>{p.title}</h3>
						<p>{p.body}</p>
						<span class="pillar-go">לכניסה ←</span>
					</a>
				))
			}
		</div>
	</section>

	<style>
		.hero {
			position: relative;
			background: radial-gradient(120% 90% at 50% 0%, #fff 0%, var(--cream) 55%, var(--peach-soft) 100%);
			text-align: center;
			padding-block: clamp(3.5rem, 10vw, 6rem) clamp(2.5rem, 7vw, 4rem);
		}
		.hero-eyebrow {
			text-transform: uppercase;
			letter-spacing: 0.24em;
			font-size: 0.8rem;
			font-weight: 700;
			color: var(--brand);
			margin: 0 0 1rem;
		}
		.hero h1 {
			font-size: clamp(2.6rem, 8vw, 5rem);
			margin: 0;
			text-wrap: balance;
		}
		.hero-sub {
			font-size: clamp(1.05rem, 2.4vw, 1.35rem);
			max-width: 42ch;
			margin: 1.2rem auto 0;
			color: var(--text);
		}
		.cta-row {
			display: flex;
			gap: 1rem;
			flex-wrap: wrap;
			justify-content: center;
			margin-top: 2.2rem;
		}
		.pillars {
			grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		}
		.pillar {
			display: flex;
			flex-direction: column;
			padding: 1.6rem;
			text-decoration: none;
			color: var(--text);
			border-top: 5px solid var(--peach);
		}
		.pillar.tint-peach {
			border-top-color: var(--apricot);
		}
		.pillar.tint-mint {
			border-top-color: #9bd6a6;
		}
		.pillar.tint-sky {
			border-top-color: var(--sky);
		}
		.pillar.tint-gold {
			border-top-color: var(--gold);
		}
		.pillar h3 {
			margin: 0 0 0.5rem;
			font-size: 1.5rem;
		}
		.pillar p {
			margin: 0 0 1rem;
			color: var(--muted);
			flex: 1;
		}
		.pillar-go {
			color: var(--brand);
			font-weight: 700;
		}
	</style>
</Base>
