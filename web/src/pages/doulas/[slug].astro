---
import Base from '../../layouts/Base.astro'
import LegacyContent from '../../components/LegacyContent.astro'
import ContactForm from '../../components/ContactForm.astro'
import {getPremiumDoulaSlugs, getPractitioner} from '../../lib/queries'
import {whatsappHref, telHref, mailtoHref, instagramHref, instagramHandle} from '../../lib/contact'
import {videoEmbedSrc} from '../../lib/video'

export async function getStaticPaths() {
  const slugs: string[] = await getPremiumDoulaSlugs()
  return slugs.map((slug) => ({params: {slug}}))
}

const {slug} = Astro.params
const d = await getPractitioner(slug!)

const wa = whatsappHref(d?.whatsapp, d?.phone)
const tel = telHref(d?.phone)
const mailto = mailtoHref(d?.email)
const ig = d?.instagramPostUrl ?? instagramHref(d?.instagram)
const igHandle = instagramHandle(d?.instagram)
const bioBlocks = Array.isArray(d?.bio) ? d!.bio : []
const videoSrc = videoEmbedSrc(d?.videoUrl)

type LegacyBlock = { _type?: string; style?: string; children?: { text?: string }[] }
const contentBlocks = (blocks: unknown[] | undefined): LegacyBlock[] =>
  Array.isArray(blocks) ? blocks.filter((block): block is LegacyBlock => typeof block === 'object' && block !== null && '_type' in block) : []

const accompanimentCards = [
  {title: 'פגישת היכרות', blocks: contentBlocks(d?.meetingInfo)},
  {title: 'מה כולל הליווי', blocks: contentBlocks(d?.services)},
  {title: 'במהלך הלידה', blocks: contentBlocks(d?.duringBirth)},
  {title: 'אחרי הלידה', blocks: contentBlocks(d?.afterBirth)},
].filter((c) => c.blocks.length > 0)

const profileFacts = [
  {title: 'בתי החולים אליהם אני מגיעה', items: d?.hospitals},
  {title: 'כלים נוספים בחדר לידה', items: d?.birthTools},
  {title: 'שירותים נוספים שאני מציעה', items: d?.additionalServices},
  {title: 'מיקום', items: d?.regions},
].filter((section) => (section.items?.length ?? 0) > 0)
---
<Base title={`${d?.name} — דולה | שבט אמהות`} description={d?.title}>
  <article class="profile-shell wrap">
    <header class="profile-head">
      {d?.photoUrl && <img class="avatar" src={`${d.photoUrl}?w=160&h=160&fit=crop`} alt={d.name} />}
      <div>
        <h1>{d?.name}</h1>
        <p class="title">{d?.title}</p>
        {d?.marketingSentence && <p class="marketing-sentence">{d.marketingSentence}</p>}
        <div class="tags">
          {(d?.hospitals || []).map((h: string) => <span class="chip">{h}</span>)}
          {(d?.supportStyle || []).map((s: string) => <span class="chip">{s}</span>)}
        </div>
      </div>
    </header>

    {d?.tagline && <p class="tagline">{d.tagline}</p>}
    {bioBlocks.length > 0 && <section class="article-body"><h2>האני מאמין שלי</h2><LegacyContent blocks={bioBlocks} /></section>}

    <div class="contact-links">
      {wa && <a class="btn btn-wa" href={wa}>וואטסאפ</a>}
      {tel && <a class="btn btn-outline" href={tel}>טלפון</a>}
      {mailto && <a class="btn btn-outline" href={mailto}>אימייל</a>}
    </div>

    {ig && (
      <a class="ig-embed" href={ig} target="_blank" rel="noopener noreferrer" aria-label={`עמוד האינסטגרם של ${d?.name}`}>
        <span class="ig-embed-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" />
            <circle cx="12" cy="12" r="4.3" />
            <circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none" />
          </svg>
        </span>
        <span class="ig-embed-body">
          <strong>{d?.name} באינסטגרם</strong>
          <span class="ig-embed-handle">{igHandle}</span>
        </span>
      </a>
    )}

    {profileFacts.length > 0 && (
      <section class="profile-facts">
        <div class="grid profile-facts-grid">
          {profileFacts.map((section) => (
            <div class="card profile-fact-card">
              <h2>{section.title}</h2>
              <ul class="profile-fact-list">
                {section.items?.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    {(d?.testimonials?.length ?? 0) > 0 && (
      <section class="reviews">
        <h2>ביקורות מאומתות ע"י שבט אמהות</h2>
        {d?.testimonials?.map((t) => (
          <blockquote>“{t.quote}” <cite>— {t.author}</cite></blockquote>
        ))}
      </section>
    )}

    {(d?.faq?.length ?? 0) > 0 && <section class="article-body"><h2>שאלות נפוצות</h2>{d?.faq?.map((item) => <details><summary>{item.q}</summary><p>{item.a}</p></details>)}</section>}

    {accompanimentCards.length > 0 && (
      <section class="accompaniment">
        <h2>עם כל הליווי</h2>
        <div class="grid accompaniment-grid">
          {accompanimentCards.map((c) => (
            <div class="card accompaniment-card">
              <h3>{c.title}</h3>
              <LegacyContent blocks={c.blocks} />
            </div>
          ))}
        </div>
      </section>
    )}

    {(d?.credentials?.length ?? 0) > 0 && <section class="article-body"><h2>הכשרות</h2><ul>{d?.credentials?.map((c) => <li>{c}</li>)}</ul></section>}

    {videoSrc && (
      <div class="phone-frame">
        <span class="phone-notch" aria-hidden="true"></span>
        <div class="phone-screen">
          <iframe src={d?.videoCoverUrl ? undefined : videoSrc} data-video-src={videoSrc} title={`סרטון ${d?.name}`} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
          {d?.videoCoverUrl && (
            <button class="video-cover-button" type="button" data-video-cover aria-label={`נגן סרטון ${d?.name}`}>
              <img src={`${d.videoCoverUrl}?w=760&fit=max`} alt={`סרטון ${d?.name}`} loading="lazy" />
              <span class="video-play-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="42" height="42" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
              </span>
            </button>
          )}
        </div>
      </div>
    )}
    {!videoSrc && d?.videoUrl && <a class="btn btn-outline" href={d.videoUrl} target="_blank" rel="noopener noreferrer">צפייה בוידאו</a>}

    {(d?.gallery?.length ?? 0) > 0 && <section class="gallery"><h2>גלריית תמונות</h2>{d?.gallery?.map((image) => image.url && <img src={`${image.url}?w=520&fit=max`} alt={`${d?.name ?? 'שבט אמהות'} - תמונת גלריה`} loading="lazy" />)}</section>}

    <ContactForm practitionerName={d?.name ?? ''} practitionerSlug={slug} practitionerType="doula" practitionerEmail={d?.email ?? ''} formId="doula-contact" />
  </article>

  {wa && <a class="btn btn-wa sticky-cta" href={wa}>כתבי וואטסאפ עכשיו ל־{d?.name}</a>}

  <style>
    .title { color:var(--muted); margin:.2rem 0; }
    .marketing-sentence { color:var(--brand); font-weight:700; margin:.45rem 0; }
    .tagline {
      font-family: var(--sans);
      font-weight: 800;
      font-size: clamp(1.15rem, 1.7vw, 1.4rem);
      color: var(--brand-deep);
      margin: 1.4rem 0 0;
      line-height: 1.5;
    }
    .accompaniment { margin: 2rem 0; }
    .accompaniment h2 { text-align:center; margin-bottom:1.4rem; }
    .accompaniment-grid { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .accompaniment-card { padding:1.6rem; }
    .accompaniment-card h3 { margin:0 0 .6rem; font-size:1.2rem; color:var(--heading); }
    .accompaniment-card :global(.legacy-content) p { margin:0; color:var(--muted); }
    .contact-links { display:flex; gap:.7rem; flex-wrap:wrap; margin:1.2rem 0; }
    .sticky-cta { position:fixed; inset-inline:auto 1rem; bottom:1rem; z-index:40; text-align:center; box-shadow:0 8px 24px -8px rgba(0,0,0,.4); }
    @media(min-width:700px){ .sticky-cta{ inset-inline:auto 2rem; } }

    .profile-facts { margin:1.6rem 0 2rem; }
    .profile-facts-grid { grid-template-columns:repeat(auto-fit, minmax(210px, 1fr)); }
    .profile-fact-card { padding:1.2rem; }
    .profile-fact-card h2 { margin:0 0 .8rem; font-size:1.15rem; color:var(--heading); }
    .profile-fact-list { display:flex; flex-wrap:wrap; gap:.5rem; margin:0; padding:0; list-style:none; }
    .profile-fact-list li { border:1px solid var(--line); border-radius:999px; padding:.25rem .65rem; background:var(--peach-soft); font-size:.92rem; }

    .ig-embed {
      display: flex;
      align-items: center;
      gap: .8rem;
      margin: 1.2rem 0;
      padding: .9rem 1.1rem;
      border-radius: 1rem;
      color: inherit;
      text-decoration: none;
      background: linear-gradient(135deg, var(--peach-soft), var(--surface));
      border: 1px solid var(--line);
      box-shadow: var(--shadow-soft);
    }
    .ig-embed-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      flex-shrink: 0;
      border-radius: 14px;
      color: var(--surface);
      background: linear-gradient(135deg, var(--peach), var(--brand));
    }
    .ig-embed-body { display: flex; flex-direction: column; gap: .15rem; }
    .ig-embed-handle { color: var(--muted); font-size: .92rem; }

    .phone-frame {
      position: relative;
      width: min(300px, 80vw);
      aspect-ratio: 9 / 19.5;
      margin: 1.8rem auto;
      background: var(--ink);
      border-radius: 2.6rem;
      padding: 12px;
      box-shadow: var(--shadow-soft);
    }
    .phone-notch {
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 38%;
      height: 22px;
      background: var(--ink);
      border-radius: 999px;
      z-index: 2;
    }
    .phone-screen {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 2rem;
      overflow: hidden;
      background: var(--ink);
    }
    .phone-screen iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .video-cover-button {
      position:absolute;
      inset:0;
      display:grid;
      place-items:center;
      width:100%;
      height:100%;
      padding:0;
      border:0;
      color:var(--surface);
      background:var(--ink);
      cursor:pointer;
    }
    .video-cover-button img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
    .video-play-icon { position:relative; z-index:1; display:grid; place-items:center; width:72px; height:72px; border-radius:50%; background:rgba(146,0,59,.86); box-shadow:var(--shadow-soft); }
    .video-cover-button:focus-visible { outline:3px solid var(--peach); outline-offset:-6px; }
    details { border:1px solid rgba(146,0,59,.14); border-radius:1rem; padding:1rem; margin:.8rem 0; background:var(--surface); }
    summary { cursor:pointer; font-weight:700; color:var(--brand); }
    .gallery { margin:2rem 0; }
    .gallery img { width:min(100%, 520px); border-radius:1rem; box-shadow:var(--shadow-soft); margin:.6rem; }
  </style>
  <script>
    document.querySelectorAll<HTMLButtonElement>("[data-video-cover]").forEach((cover) => {
      cover.addEventListener("click", () => {
        const iframe = cover.parentElement?.querySelector<HTMLIFrameElement>("iframe[data-video-src]");
        const src = iframe?.dataset.videoSrc;
        if (!iframe || !src) return;
        const separator = src.includes("?") ? "&" : "?";
        iframe.src = `${src}${separator}autoplay=1`;
        cover.hidden = true;
      }, { once: true });
    });
  </script>
</Base>
