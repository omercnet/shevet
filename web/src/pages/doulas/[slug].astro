---
import Base from '../../layouts/Base.astro'
import LegacyContent from '../../components/LegacyContent.astro'
import ContactForm from '../../components/ContactForm.astro'
import {getPremiumDoulaSlugs, getPractitioner} from '../../lib/queries'
import {whatsappHref, telHref, mailtoHref, instagramHref} from '../../lib/contact'
import {videoEmbedSrc} from '../../lib/video'

export async function getStaticPaths() {
  const slugs: string[] = await getPremiumDoulaSlugs()
  return slugs.map((slug) => ({params: {slug}}))
}

const {slug} = Astro.params
const d = await getPractitioner(slug!)

const wa = whatsappHref(d?.whatsapp, d?.phone)
const tel = telHref(d?.phone)
const mailto = mailtoHref(d?.email)
const ig = d?.instagramPostUrl ?? instagramHref(d?.instagram)
const bioBlocks = Array.isArray(d?.bio) ? d!.bio : []
const serviceBlocks = Array.isArray(d?.services) ? d!.services : []
const videoSrc = videoEmbedSrc(d?.videoUrl)
---
<Base title={`${d?.name} — דולה | שבט אמהות`} description={d?.title}>
  <article class="profile-shell wrap">
    <header class="profile-head">
      {d?.photoUrl && <img class="avatar" src={`${d.photoUrl}?w=160&h=160&fit=crop`} alt={d.name} />}
      <div>
        <h1>{d?.name}</h1>
        <p class="title">{d?.title}</p>
        {d?.marketingSentence && <p class="marketing-sentence">{d.marketingSentence}</p>}
        <div class="tags">
          {(d?.hospitals || []).map((h: string) => <span class="chip">{h}</span>)}
          {(d?.supportStyle || []).map((s: string) => <span class="chip">{s}</span>)}
        </div>
      </div>
    </header>

    {d?.tagline && <p class="tagline">{d.tagline}</p>}
    {bioBlocks.length > 0 && <section class="article-body"><h2>האני מאמין שלי</h2><LegacyContent blocks={bioBlocks} /></section>}

    <div class="contact-links">
      {wa && <a class="btn btn-wa" href={wa}>וואטסאפ</a>}
      {tel && <a class="btn btn-outline" href={tel}>טלפון</a>}
      {mailto && <a class="btn btn-outline" href={mailto}>אימייל</a>}
      {ig && <a class="btn btn-outline" href={ig} target="_blank" rel="noopener noreferrer">Instagram</a>}
    </div>

    {(d?.testimonials?.length ?? 0) > 0 && (
      <section class="reviews">
        {d?.testimonials?.map((t) => (
          <blockquote>“{t.quote}” <cite>— {t.author}</cite></blockquote>
        ))}
      </section>
    )}

    {serviceBlocks.length > 0 && <section class="article-body"><h2>מה כולל הליווי</h2><LegacyContent blocks={serviceBlocks} /></section>}
    {(d?.faq?.length ?? 0) > 0 && <section class="article-body"><h2>שאלות ותשובות</h2>{d?.faq?.map((item) => <details><summary>{item.q}</summary><p>{item.a}</p></details>)}</section>}
    {(d?.credentials?.length ?? 0) > 0 && <section class="article-body"><h2>הכשרות</h2><ul>{d?.credentials?.map((c) => <li>{c}</li>)}</ul></section>}

    {videoSrc && (
      <div class="phone-frame">
        <span class="phone-notch" aria-hidden="true"></span>
        <div class="phone-screen">
          <iframe src={videoSrc} title={`סרטון ${d?.name}`} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
        </div>
      </div>
    )}
    {d?.videoCoverUrl && d?.videoUrl && <a href={d.videoUrl} target="_blank" rel="noopener noreferrer"><img class="video-cover" src={`${d.videoCoverUrl}?w=760&fit=max`} alt={`סרטון ${d?.name}`} /></a>}
    {!videoSrc && d?.videoUrl && <a class="btn btn-outline" href={d.videoUrl} target="_blank" rel="noopener noreferrer">צפייה בוידאו</a>}

    {(d?.gallery?.length ?? 0) > 0 && <section class="gallery"><h2>גלריית תמונות</h2>{d?.gallery?.map((image) => image.url && <img src={`${image.url}?w=520&fit=max`} alt={`${d?.name ?? 'שבט אמהות'} - תמונת גלריה`} loading="lazy" />)}</section>}

    <ContactForm practitionerName={d?.name ?? ''} practitionerSlug={slug} practitionerType="doula" practitionerEmail={d?.email ?? ''} formId="doula-contact" />
  </article>

  {wa && <a class="btn btn-wa sticky-cta" href={wa}>כתבי וואטסאפ עכשיו ל־{d?.name}</a>}

  <style>
    .title { color:var(--muted); margin:.2rem 0; }
    .marketing-sentence { color:var(--brand); font-weight:700; margin:.45rem 0; }
    .tagline {
      font-family: var(--sans);
      font-weight: 800;
      font-size: clamp(1.15rem, 1.7vw, 1.4rem);
      color: var(--brand-deep);
      margin: 1.4rem 0 0;
      line-height: 1.5;
    }
    .contact-links { display:flex; gap:.7rem; flex-wrap:wrap; margin:1.2rem 0; }
    .sticky-cta { position:fixed; inset-inline:auto 1rem; bottom:1rem; z-index:40; text-align:center; box-shadow:0 8px 24px -8px rgba(0,0,0,.4); }
    @media(min-width:700px){ .sticky-cta{ inset-inline:auto 2rem; } }

    .phone-frame {
      position: relative;
      width: min(300px, 80vw);
      aspect-ratio: 9 / 19.5;
      margin: 1.8rem auto;
      background: #111;
      border-radius: 2.6rem;
      padding: 12px;
      box-shadow: var(--shadow-soft);
    }
    .phone-notch {
      position: absolute;
      top: 12px;
      left: 50%;
      transform: translateX(-50%);
      width: 38%;
      height: 22px;
      background: #111;
      border-radius: 999px;
      z-index: 2;
    }
    .phone-screen {
      position: relative;
      width: 100%;
      height: 100%;
      border-radius: 2rem;
      overflow: hidden;
      background: #000;
    }
    .phone-screen iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    details { border:1px solid rgba(146,0,59,.14); border-radius:1rem; padding:1rem; margin:.8rem 0; background:#fff; }
    summary { cursor:pointer; font-weight:700; color:var(--brand); }
    .video-cover { width:min(100%, 760px); border-radius:1.4rem; box-shadow:var(--shadow-soft); margin:1.5rem 0; }
    .gallery { margin:2rem 0; }
    .gallery img { width:min(100%, 520px); border-radius:1rem; box-shadow:var(--shadow-soft); margin:.6rem; }
  </style>
</Base>
