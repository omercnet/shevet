---
import Base from '../../layouts/Base.astro'
import {getSiteSettings} from '../../lib/queries'

const settings = await getSiteSettings()
---
<Base title="הצטרפות דולות — שבט אמהות" description="דולות, הצטרפו בחינם למאגר שבט אמהות: ממלאות טופס, אנחנו מאשרות, ומופיעות במאגר.">
  <section class="wrap join">
    <h1>הצטרפו למאגר הדולות</h1>
    <p class="lead">רוצות להופיע במאגר הדולות של שבט אמהות? ההצטרפות חינמית ופשוטה.</p>

    <ol class="join-flow">
      <li><span class="num">1</span> ממלאות את טופס ההרשמה</li>
      <li><span class="num">2</span> אנחנו מאשרות את הפרטים</li>
      <li><span class="num">3</span> מופיעות במאגר</li>
    </ol>

    <div class="form-block">
      {settings?.matchmakingFormEmbed ? (
        <div class="embed" set:html={settings.matchmakingFormEmbed}></div>
      ) : (
        <p class="placeholder">טופס ההרשמה יתווסף בקרוב.</p>
      )}
    </div>
  </section>

  <style>
    .join { max-width:760px; }
    .lead { color:var(--muted); font-size:1.1rem; }
    .form-block { margin-top:2.5rem; padding:2rem; }
    .placeholder { margin:0; color:var(--muted); text-align:center; }
    .embed { width:100%; }
  </style>
</Base>
