---
import Base from '../../layouts/Base.astro'
import {getDoulas, getSiteSettings} from '../../lib/queries'
import {instagramHref, mailtoHref, telHref, whatsappHref} from '../../lib/contact'
import {SUPPORT_STYLES, BUDGET_BANDS} from '../../../shared/searchOptions'

const doulas = (await getDoulas()).map((d) => ({
  ...d,
  whatsappUrl: whatsappHref(d.whatsapp, d.phone),
  phoneUrl: telHref(d.phone),
  emailUrl: mailtoHref(d.email),
  instagramUrl: instagramHref(d.instagram),
}))
const hospitals = [...new Set(doulas.flatMap((d) => d.hospitals ?? []))].sort()
const settings = await getSiteSettings()
---
<Base title="חיפוש דולות — שבט אמהות" description="מצאי דולה לפי בית חולים, תאריך לידה, סגנון ליווי ותקציב.">
  <section class="wrap">
    <h1>נבחרת הדולות של שבט אמהות</h1>
    <p>מצאי דולה לפי בית חולים, סגנון ליווי ותקציב. החיפוש מיידי.</p>
    <p><a class="btn btn-outline" href="/doulas/join/">רוצה להצטרף לנבחרת?</a></p>

    <form class="filter-panel" id="doula-filters">
      <label>בית חולים
        <select name="hospital"><option value="">הכול</option>
          {hospitals.map((h: string) => <option value={h}>{h}</option>)}
        </select>
      </label>
      <label>תאריך לידה משוער
        <input type="date" name="dueDate" />
      </label>
      <label>סגנון ליווי
        <select name="style"><option value="">הכול</option>
          {SUPPORT_STYLES.map((s) => <option value={s}>{s}</option>)}
        </select>
      </label>
      <label>תקציב
        <select name="budget"><option value="">הכול</option>
          {BUDGET_BANDS.map((b) => <option value={b.value}>{b.title}</option>)}
        </select>
      </label>
      <button type="button" id="reset">ניקוי</button>
    </form>

    <p id="count">{doulas.length} דולות</p>
    <div class="grid" id="results">
      {doulas.map((d) => {
        const detailHref = d.tier === 'premium' ? `/doulas/${d.slug}/` : undefined
        return (
          <article class="card directory-card doula-card">
            {d.photo && (detailHref ? <a class="card-media" href={detailHref}><img src={`${d.photo}?w=480&h=360&fit=crop`} alt={d.name} loading="lazy" /></a> : <div class="card-media"><img src={`${d.photo}?w=480&h=360&fit=crop`} alt={d.name} loading="lazy" /></div>)}
            <div class="card-body">
              <h3>{detailHref ? <a href={detailHref}>{d.name}</a> : d.name}</h3>
              {d.title && <p class="card-title">{d.title}</p>}
              <div class="tags">{[...(d.hospitals ?? []), ...(d.supportStyle ?? [])].slice(0, 3).map((t) => <span class="chip">{t}</span>)}</div>
              {detailHref && <div class="card-actions"><a class="more" href={detailHref}>לפרטים נוספים ←</a></div>}
              <div class="card-actions contact-links">
                {d.whatsappUrl && <a class="btn btn-wa" href={d.whatsappUrl}>וואטסאפ</a>}
                {d.phoneUrl && <a class="more" href={d.phoneUrl}>טלפון</a>}
                {d.emailUrl && <a class="more" href={d.emailUrl}>אימייל</a>}
                {d.instagramUrl && <a class="more" href={d.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>}
              </div>
            </div>
          </article>
        )
      })}
    </div>

    {settings?.matchmakingFormEmbed && (
      <aside class="matchmaking">
        <h2>לא בטוחות? נעזור לכן למצוא</h2>
        <p>מלאו את הטופס ונשלח אתכן לדולה שמתאימה לכן.</p>
        <div class="embed" set:html={settings.matchmakingFormEmbed}></div>
      </aside>
    )}
  </section>

  <script type="application/json" id="data" is:inline set:html={JSON.stringify(doulas)}></script>
  <script>
    interface Row {
      slug: string; name: string; title?: string; tier?: string; photo?: string; whatsappUrl?: string; phoneUrl?: string; emailUrl?: string; instagramUrl?: string;
      hospitals?: string[]; supportStyle?: string[]; budget?: string;
    }
    const dataEl = document.getElementById("data");
    const form = document.getElementById("doula-filters") as HTMLFormElement | null;
    const out = document.getElementById("results");
    const count = document.getElementById("count");
    const reset = document.getElementById("reset");

    if (dataEl && form && out && count) {
      const data: Row[] = JSON.parse(dataEl.textContent ?? "[]");
      const esc = (s: string): string =>
        s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] ?? c);
      const card = (d: Row): string => {
        const name = esc(d.name);
        const tags = [...(d.hospitals ?? []), ...(d.supportStyle ?? [])]
          .slice(0, 3)
          .map((t) => `<span class="chip">${esc(t)}</span>`)
          .join("");
        const href = d.tier === "premium" ? `/doulas/${encodeURIComponent(d.slug)}/` : "";
        const wa = d.whatsappUrl
          ? `<a class="btn btn-wa" href="${esc(d.whatsappUrl)}">וואטסאפ</a>`
          : "";
        const phone = d.phoneUrl ? `<a class="more" href="${esc(d.phoneUrl)}">טלפון</a>` : "";
        const email = d.emailUrl ? `<a class="more" href="${esc(d.emailUrl)}">אימייל</a>` : "";
        const instagram = d.instagramUrl ? `<a class="more" href="${esc(d.instagramUrl)}" target="_blank" rel="noopener noreferrer">Instagram</a>` : "";
        const image = d.photo ? `<img src="${encodeURI(d.photo)}?w=480&h=360&fit=crop" alt="${name}" loading="lazy">` : "";
        const media = image ? (href ? `<a class="card-media" href="${href}">${image}</a>` : `<div class="card-media">${image}</div>`) : "";
        const title = d.title ? `<p class="card-title">${esc(d.title)}</p>` : "";
        const heading = href ? `<a href="${href}">${name}</a>` : name;
        const details = href ? `<div class="card-actions"><a class="more" href="${href}">לפרטים נוספים ←</a></div>` : "";
        return `<article class="card directory-card doula-card">
          ${media}
          <div class="card-body">
            <h3>${heading}</h3>
            ${title}
            <div class="tags">${tags}</div>
            ${details}
            <div class="card-actions contact-links">${wa}${phone}${email}${instagram}</div>
          </div>
        </article>`;
      };
      const apply = (): void => {
        const f = new FormData(form);
        const hospital = f.get("hospital");
        const style = f.get("style");
        const budget = f.get("budget");
        const res = data.filter(
          (d) =>
            (!hospital || (d.hospitals ?? []).includes(hospital as string)) &&
            (!style || (d.supportStyle ?? []).includes(style as string)) &&
            (!budget || d.budget === budget),
        );
        // dueDate currently informational — matching rule TBD with Keren
        out.innerHTML = res.map(card).join("");
        count.textContent = `${res.length} דולות`;
      };
      form.addEventListener("input", apply);
      reset?.addEventListener("click", () => {
        HTMLFormElement.prototype.reset.call(form);
        apply();
      });
      apply();
    }
  </script>

  <style>
    #count { color:var(--muted); font-weight:600; margin:.5rem 0 1.2rem; }
    .matchmaking { margin-top:3.5rem; background:linear-gradient(160deg,var(--peach-soft),var(--peach)); border-radius:18px; padding:2rem; }
    .matchmaking h2 { margin-top:0; }
    .matchmaking .embed { margin-top:1rem; }
  </style>
</Base>
