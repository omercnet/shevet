---
import Base from '../../layouts/Base.astro'
import {getDoulas, getSiteSettings} from '../../lib/queries'
import {SUPPORT_STYLES, BUDGET_BANDS} from '../../../shared/searchOptions'

const doulas = await getDoulas()
const hospitals = [...new Set(doulas.flatMap((d: any) => d.hospitals || []))].sort()
const settings = await getSiteSettings()
---
<Base title="חיפוש דולות — שבט אמהות" description="מצאי דולה לפי בית חולים, תאריך לידה, סגנון ליווי ותקציב.">
  <section class="wrap">
    <h1>חיפוש דולות</h1>
    <p>סננו לפי מה שחשוב לכן. החיפוש מיידי.</p>

    <form class="filters" id="doula-filters">
      <label>בית חולים
        <select name="hospital"><option value="">הכול</option>
          {hospitals.map((h: string) => <option value={h}>{h}</option>)}
        </select>
      </label>
      <label>תאריך לידה משוער
        <input type="date" name="dueDate" />
      </label>
      <label>סגנון ליווי
        <select name="style"><option value="">הכול</option>
          {SUPPORT_STYLES.map((s) => <option value={s}>{s}</option>)}
        </select>
      </label>
      <label>תקציב
        <select name="budget"><option value="">הכול</option>
          {BUDGET_BANDS.map((b) => <option value={b.value}>{b.title}</option>)}
        </select>
      </label>
      <button type="button" id="reset">ניקוי</button>
    </form>

    <p id="count"></p>
    <div class="grid" id="results"></div>

    {settings?.matchmakingFormEmbed && (
      <aside class="matchmaking">
        <h2>לא בטוחות? נעזור לכן למצוא</h2>
        <p>מלאו את הטופס ונשלח אתכן לדולה שמתאימה לכן.</p>
        <div class="embed" set:html={settings.matchmakingFormEmbed}></div>
      </aside>
    )}
  </section>

  <script type="application/json" id="data" is:inline set:html={JSON.stringify(doulas)}></script>
  <script>
    interface Row {
      slug: string; name: string; photo?: string; whatsapp?: string;
      hospitals?: string[]; supportStyle?: string[]; budget?: string;
    }
    const dataEl = document.getElementById("data");
    const form = document.getElementById("doula-filters") as HTMLFormElement | null;
    const out = document.getElementById("results");
    const count = document.getElementById("count");
    const reset = document.getElementById("reset");

    if (dataEl && form && out && count) {
      const data: Row[] = JSON.parse(dataEl.textContent ?? "[]");
      const esc = (s: string): string =>
        s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] ?? c);
      const card = (d: Row): string => {
        const name = esc(d.name);
        const tags = [...(d.hospitals ?? []), ...(d.supportStyle ?? [])]
          .slice(0, 3)
          .map((t) => `<span class="chip">${esc(t)}</span>`)
          .join("");
        const href = `/doulas/${encodeURIComponent(d.slug)}/`;
        const wa = d.whatsapp
          ? `<a class="btn btn-wa" href="https://wa.me/${d.whatsapp.replace(/\D/g, "")}">וואטסאפ</a>`
          : "";
        const media = d.photo
          ? `<a class="card-media" href="${href}"><img src="${encodeURI(d.photo)}?w=480&h=360&fit=crop" alt="${name}" loading="lazy"></a>`
          : "";
        return `<article class="card doula-card">
          ${media}
          <div class="card-body">
            <h3><a href="${href}">${name}</a></h3>
            <div class="tags">${tags}</div>
            <div class="card-actions"><a class="more" href="${href}">לפרטים נוספים ←</a>${wa}</div>
          </div>
        </article>`;
      };
      const apply = (): void => {
        const f = new FormData(form);
        const hospital = f.get("hospital");
        const style = f.get("style");
        const budget = f.get("budget");
        const res = data.filter(
          (d) =>
            (!hospital || (d.hospitals ?? []).includes(hospital as string)) &&
            (!style || (d.supportStyle ?? []).includes(style as string)) &&
            (!budget || d.budget === budget),
        );
        // dueDate currently informational — matching rule TBD with Keren
        out.innerHTML = res.map(card).join("");
        count.textContent = `${res.length} דולות`;
      };
      form.addEventListener("input", apply);
      reset?.addEventListener("click", () => {
        form.reset();
        apply();
      });
      apply();
    }
  </script>

  <style>
    .filters { display:flex; gap:1rem 1.2rem; flex-wrap:wrap; align-items:end; background:linear-gradient(160deg,var(--peach-soft),var(--peach)); padding:1.5rem; border-radius:18px; margin:1.5rem 0; }
    .filters label { display:flex; flex-direction:column; font-size:.8rem; gap:.35rem; color:var(--brand); font-weight:700; }
    .filters select, .filters input { padding:.6rem .7rem; border:1px solid var(--line); border-radius:10px; font-family:inherit; background:#fff; min-width:11ch; }
    .filters select:focus, .filters input:focus { outline:2px solid var(--brand); outline-offset:1px; }
    .filters button { align-self:end; background:#fff; border:1px solid var(--brand); color:var(--brand); border-radius:999px; padding:.6rem 1.2rem; cursor:pointer; font-weight:700; }
    .filters button:hover { background:var(--brand); color:#fff; }
    #count { color:var(--muted); font-weight:600; margin:.5rem 0 1.2rem; }
    .doula-card .card-media { display:block; aspect-ratio:4/3; }
    .doula-card .card-media img, .doula-card .ph { width:100%; height:100%; object-fit:cover; display:block; }
    .doula-card .ph { background:linear-gradient(135deg,var(--peach-soft),var(--peach)); }
    .doula-card .card-body { padding:1.1rem 1.2rem 1.3rem; }
    .doula-card h3 { margin:0 0 .5rem; font-size:1.35rem; }
    .doula-card h3 a { text-decoration:none; }
    .doula-card .tags { display:flex; flex-wrap:wrap; gap:.35rem; margin-bottom:1rem; min-height:1.4rem; }
    .doula-card .card-actions { display:flex; align-items:center; justify-content:space-between; gap:.6rem; flex-wrap:wrap; }
    .doula-card .more { color:var(--brand); font-weight:700; text-decoration:none; }
    .doula-card .btn-wa { padding:.45rem .9rem; font-size:.9rem; }
    .matchmaking { margin-top:3.5rem; background:linear-gradient(160deg,var(--peach-soft),var(--peach)); border-radius:18px; padding:2rem; }
    .matchmaking h2 { margin-top:0; }
    .matchmaking .embed { margin-top:1rem; }
  </style>
</Base>
