---
import Base from "../../layouts/Base.astro";
import { getBenefits } from "../../lib/queries";

const benefits = await getBenefits();

const CATEGORIES: { value: string; label: string }[] = [
	{ value: "pregnancy", label: "הריון" },
	{ value: "postpartum", label: "לאחר לידה" },
	{ value: "baby", label: "תינוקות" },
];
---
<Base title="מועדון הטבות — שבט אמהות" description="הטבות וקופונים בלעדיים לחברות הקהילה — להריון, לאחר לידה ולתינוקות.">
  <section class="wrap">
    <h1>מועדון הטבות</h1>
    <p>הטבות וקופונים בלעדיים מהשותפים שלנו. סננו לפי שלב.</p>

    <div class="cats" id="cats" role="group" aria-label="סינון לפי קטגוריה">
      <button type="button" class="chip is-active" data-cat="">הכול</button>
      {CATEGORIES.map((c) => (
        <button type="button" class="chip" data-cat={c.value}>{c.label}</button>
      ))}
    </div>

    <div class="grid" id="results"></div>
    <p class="empty" id="empty" hidden>אין הטבות עדיין</p>
  </section>

  <script type="application/json" id="data" is:inline set:html={JSON.stringify(benefits)}></script>
  <script>
    interface Benefit {
      slug?: string;
      partner: string;
      logo?: string;
      category?: string;
      discount?: string;
      description?: string;
      couponCode?: string;
      redeemUrl?: string;
    }
    const esc = (s: string): string =>
      s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");

    const dataEl = document.getElementById("data");
    const cats = document.getElementById("cats");
    const out = document.getElementById("results");
    const empty = document.getElementById("empty");

    if (dataEl && cats && out && empty) {
      const data: Benefit[] = JSON.parse(dataEl.textContent ?? "[]");
      const card = (b: Benefit): string => {
        const logo = b.logo ? `<img class="logo" src="${esc(b.logo)}?w=160&h=80&fit=max" alt="${esc(b.partner)}">` : "";
        const discount = b.discount ? `<p class="discount">${esc(b.discount)}</p>` : "";
        const desc = b.description ? `<p class="desc">${esc(b.description)}</p>` : "";
        const code = b.couponCode ? `<p class="code">קוד קופון: <span>${esc(b.couponCode)}</span></p>` : "";
        const redeem = b.redeemUrl
          ? `<a class="btn" href="${esc(b.redeemUrl)}" target="_blank" rel="noopener">למימוש</a>`
          : "";
        return `<article class="card benefit-card">${logo}<h3>${esc(b.partner)}</h3>${discount}${desc}${code}${redeem}</article>`;
      };
      let active = "";
      const apply = (): void => {
        const res = data.filter((b) => !active || b.category === active);
        out.innerHTML = res.map(card).join("");
        empty.hidden = res.length > 0;
      };
      cats.addEventListener("click", (e: MouseEvent) => {
        const target = e.target as HTMLElement | null;
        const btn = target?.closest<HTMLButtonElement>("button[data-cat]");
        if (!btn) return;
        active = btn.dataset.cat ?? "";
        for (const b of cats.querySelectorAll<HTMLButtonElement>("button[data-cat]")) {
          b.classList.toggle("is-active", b === btn);
        }
        apply();
      });
      apply();
    }
  </script>

  <style>
    .cats { display:flex; gap:.5rem; flex-wrap:wrap; margin:1.5rem 0; }
    .cats .chip { cursor:pointer; border:1px solid var(--line); background:var(--surface); }
    .cats .chip.is-active { background:var(--brand); color:var(--surface); border-color:var(--brand); }
    .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1.2rem; }
    .empty { color:var(--muted); padding:2rem 0; }
  </style>
</Base>
