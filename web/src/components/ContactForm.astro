---
interface Props {
  practitionerName: string
  practitionerSlug?: string
  practitionerType?: string
  practitionerEmail?: string
  formId?: string
}
const { practitionerName, practitionerSlug = '', practitionerType = '', practitionerEmail = '', formId = 'practitioner-contact' } = Astro.props
---
<section class="contact-form-section">
  <h2>שליחת פנייה</h2>
  <form
    name={formId}
    method="POST"
    data-netlify="true"
    data-netlify-honeypot="bot-field"
    class="netlify-form"
  >
    <input type="hidden" name="form-name" value={formId} />
    <input type="hidden" name="practitioner" value={practitionerName} />
    <input type="hidden" name="practitionerSlug" value={practitionerSlug} />
    <input type="hidden" name="practitionerType" value={practitionerType} />
    <input type="hidden" name="practitionerEmail" value={practitionerEmail} />
    <p hidden><label>אל תמלאי שדה זה: <input name="bot-field" /></label></p>
    <div class="form-row">
      <label for="cf-name">שם מלא *</label>
      <input id="cf-name" name="name" type="text" required autocomplete="name" />
    </div>
    <div class="form-row">
      <label for="cf-phone">טלפון *</label>
      <input id="cf-phone" name="phone" type="tel" required autocomplete="tel" />
    </div>
    <div class="form-row">
      <label for="cf-email">דואר אלקטרוני</label>
      <input id="cf-email" name="email" type="email" autocomplete="email" />
    </div>
    <div class="form-row">
      <label for="cf-due">תאריך לידה משוער</label>
      <input id="cf-due" name="dueDate" type="month" />
    </div>
    <div class="form-row">
      <label for="cf-city">עיר</label>
      <input id="cf-city" name="city" type="text" autocomplete="address-level2" />
    </div>
    <div class="form-row">
      <label for="cf-hospital">בית חולים מועדף</label>
      <input id="cf-hospital" name="hospital" type="text" />
    </div>
    <div class="form-row">
      <label for="cf-needs">מה את צריכה?</label>
      <textarea id="cf-needs" name="needs" rows="4"></textarea>
    </div>
    <div class="form-row form-row--check">
      <label>
        <input type="checkbox" name="consent" required />
        קראתי את <a href="/privacy/" target="_blank">מדיניות הפרטיות</a> ואני מסכימה לקבלת מידע.
      </label>
    </div>
    <button type="submit" class="btn">שלחי פנייה</button>
  </form>
</section>
<style>
  .contact-form-section { margin-top:2.5rem; }
  .netlify-form { display:flex; flex-direction:column; gap:1rem; max-width:500px; }
  .form-row { display:flex; flex-direction:column; gap:.3rem; }
  .form-row label { font-weight:600; font-size:.9rem; }
  .form-row input, .form-row textarea { border:1px solid var(--line); border-radius:8px; padding:.5rem .7rem; font:inherit; background:var(--surface); width:100%; box-sizing:border-box; }
  .form-row input:focus-visible, .form-row textarea:focus-visible { outline:2px solid var(--brand); outline-offset:1px; }
  .form-row--check label { display:flex; gap:.5rem; align-items:flex-start; font-weight:400; }
  .form-row--check input { width:auto; flex-shrink:0; margin-top:.2rem; }
</style>
