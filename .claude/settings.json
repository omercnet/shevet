{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./web/.env)",
      "Read(./web/.env.*)",
      "Read(./studio/.env)",
      "Read(./studio/.env.*)",
      "Read(./tools/import/.env)",
      "Read(./tools/import/.env.*)",
      "Read(./**/*wxr*)",
      "Read(./**/*.xml)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/ensure-node-deps.mjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/session-start.mjs"
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-map.mjs"
          }
        ]
      }
    ]
  }
}
